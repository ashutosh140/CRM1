# ─────────────────────────────────────────────────────────────
#  AI CRM — Environment Variables
#  Copy this file to `.env` and fill in the values.
# ─────────────────────────────────────────────────────────────

# REQUIRED — PostgreSQL connection string (Neon / Supabase / local)
# Neon example:    postgresql://user:pass@ep-xxx.aws.neon.tech/neondb?sslmode=require
# Supabase example: postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres
DATABASE_URL="postgresql://user:password@localhost:5432/aicrm?schema=public"

# REQUIRED — secret used to sign session JWTs (any long random string)
# Generate one:  openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string-please"

# OPTIONAL — OpenAI key. If absent, AI features run in MOCK mode (app still works).
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Email via Brevo (https://app.brevo.com → SMTP & API)
BREVO_API_KEY=""
BREVO_SENDER_EMAIL="no-reply@yourdomain.com"
BREVO_SENDER_NAME="AI CRM"
# Brevo SMTP (alternative to API)
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# OPTIONAL — other integrations (mock until provided)
WHATSAPP_API_TOKEN=""
WHATSAPP_PHONE_ID=""
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# App base URL (used for links in emails/PDFs)
APP_URL="http://localhost:3000"
